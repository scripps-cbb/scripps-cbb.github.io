source "https://rubygems.org"

# GitHub Pages — pinned to the version GH Pages currently runs.
# https://pages.github.com/versions/
gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end

# Performance-booster for watching directories on Windows / macOS
gem "wdm", "~> 0.1.1", :platforms => [:mingw, :x64_mingw, :mswin]

# Lock to a Ruby compatible with GitHub Pages
gem "webrick", "~> 1.8"
